# ─── Database ─────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://bandconnect:bandconnect_pass@localhost:5432/bandconnect

# ─── Security ─────────────────────────────────────────────────────────────────
# LOCAL DEVELOPMENT: You may leave SECRET_KEY empty or omit it entirely.
#   The backend will use a clearly-labelled dev-only fallback key and print a
#   visible warning. Real JWT authentication still works.
# PRODUCTION: SECRET_KEY must be a cryptographically secure value (min 32 chars).
#   Generate one: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=7

# ─── Redis ────────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0

# ─── CORS ─────────────────────────────────────────────────────────────────────
ALLOWED_ORIGINS=["http://localhost:3000"]

# ─── AWS S3 (leave blank to use local file storage in dev) ────────────────────
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_BUCKET_NAME=
AWS_REGION=ap-south-1

# ─── Razorpay ─────────────────────────────────────────────────────────────────
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=

# ─── Email / SMTP ────────────────────────────────────────────────────────────
SMTP_HOST=smtp.mailtrap.io
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
FROM_EMAIL=noreply@bandconnect.in
FROM_NAME=BandConnect

# ─── App ──────────────────────────────────────────────────────────────────────
ENVIRONMENT=development
APP_NAME=BandConnect
APP_URL=http://localhost:3000
API_URL=http://localhost:8000
